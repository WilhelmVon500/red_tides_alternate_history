- @united_left_coalition_saxony
- @grand_coalition_saxony
- @bourgeois_coalition_saxony
- @right_coalition_saxony
- @no_majority_saxony




@kpd_tolerates_spd
title: The <span style="color: #8B0000;">**KPD**</span> will tolerate Wilhelm Buck's cabinet.
subtitle: At least not a United Left government...
view-if: united_left_coalition_saxony > 50 and year = 1922
on-arrival: in_spd_kpd_toleration_saxony = 1; saxony_leader = "Buck"; saxony_leader_party = "SPD";
face-image: img/portraits/BuckWilhelm.jpg

