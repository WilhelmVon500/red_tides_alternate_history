Wilhelm Buck WIP


@united_left_coalition_saxony
title: The Social Democrats form a coalition with the <span style="color: #8B0000;">**KPD**</span>!
subtitle: <span style="color: #E3000F;">**SPD**</span> + <span style="color: #8B0000;">**KPD**</span> ([+ united_left_coalition_saxony +]%)
view-if: united_left_coalition_saxony > 50 and year != 1922
on-arrival: in_united_left_coalition_saxony = 1;
