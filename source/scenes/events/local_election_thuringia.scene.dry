title: Thuringia Landtag Election
view-if: (year = next_election_year_thuringia and month >= next_election_month_thuringia and (week = next_election_week_thuringia or not weeks_enabled)) or (year > next_election_year_thuringia)
new-page: true
tags: event
priority: 3
on-arrival: next_election_year_thuringia = next_election_year_thuringia + 3;

= Thuringia Landtag Elections, [+ month : month +] [+ year +]

The Thuringian state elections are to be held now.

- @thuringia: May we do our best...
  
@thuringia
on-arrival: {!
for (var c of Q.classes) {
    var class_votes = 0;
    for (var party of Q.parties) {
        if (Q[c + '_' + party] < 0) {
            Q[c + '_' + party] = 0;
        }
        class_votes += Q[c + '_' + party];
    }
    for (var party of Q.parties) {
        Q[c + '_' + party + '_normalized_thuringia'] = Math.round(100 * Q[c + '_' + party] / class_votes);
    }
}

// Define adjustment factors
if (Q.year == 1924) {
    Q.adjustmentFactors_kpd_thuringia = 1.2;
    Q.adjustmentFactors_spd_thuringia = 1.3;
    Q.adjustmentFactors_fvp_thuringia = 1.1;
    Q.adjustmentFactors_bb_thuringia = 0.0;
    Q.adjustmentFactors_z_thuringia = 0.05;
    Q.adjustmentFactors_nlp_thuringia = 1.4;
    Q.adjustmentFactors_csvd_thuringia = 0.7;
    Q.adjustmentFactors_wp_thuringia = 2.5;
    Q.adjustmentFactors_rlb_thuringia = 6.5;
    Q.adjustmentFactors_kvp_thuringia = 0.8;
    Q.adjustmentFactors_dnvp_thuringia = 0.8;
    Q.adjustmentFactors_kswr_thuringia = 0.8;
    Q.adjustmentFactors_dap_thuringia = 1.5;
    Q.adjustmentFactors_other_thuringia = 0.1;
}



// Calculate support for each of the parties
var total_support = 0;
for (var party of Q.parties) {
    var party_support = 0;
    for (var c of Q.classes) {
        party_support += Q[c] * Q[c + '_' + party + '_normalized_thuringia'];
    }
    // Apply adjustment factor
    Q[party + '_support'] = party_support * Q['adjustmentFactors_' + party + '_thuringia'];
    total_support += Q[party + '_support'];
}
console.log(total_support)
// Normalize support (fraction)
for (var party of Q.parties) {
    Q[party + '_normalized_thuringia'] = Q[party + '_support'] / total_support;
    console.log(Q[party + '_support'])
    console.log(total_support)
    Q[party + '_votes_thuringia'] = Math.round(Q[party + '_normalized_thuringia'] * 1000) / 10;
}


var new_party_sum = 0;
for (var party of Q.parties) {
    Q[party + '_tl'] = 0;
    Q[party + '_seats_thuringia'] = 0;
    if (Q[party + '_banned']) {
        Q[party + '_election_votes_thuringia'] = 0;
    } else {
        Q[party + '_election_votes_thuringia'] = parseFloat((Q[party+'_votes_thuringia']).toFixed(1));
    }
    new_party_sum += Q[party + '_election_votes_thuringia'];
}

var other_votes_fix = Q.other_election_votes_thuringia
Q.other_election_votes_thuringia = parseFloat((Q.other_election_votes_thuringia * 0.3).toFixed(1));
var new_new_party_sum = new_party_sum + Q.other_election_votes_thuringia - other_votes_fix;

// calculate new party sum
if (new_party_sum > 0) {
    for (var party of Q.parties) {
        if (Q[party + '_election_votes_thuringia'] > 0 && !(Q[party + '_election_votes_thuringia'] < Q.electoral_threshold) && !(Q.electoral_threshold > 1 && party == 'other')) {
            Q[party + '_tl'] = parseFloat((Q[party + '_election_votes_thuringia']*100/new_new_party_sum).toFixed(1));
            Q[party + '_election_votes_thuringia'] = parseFloat((Q[party + '_election_votes_thuringia']*100/new_party_sum).toFixed(1));
        } else {
            Q[party + '_election_votes_thuringia'] = parseFloat((Q[party + '_election_votes_thuringia']*100/new_party_sum).toFixed(1));
            Q[party + '_tl'] = 0;
        }
        Q[party + '_tl'] = parseFloat((Q[party+'_tl']).toFixed(1));
    }
}

Q.other_election_votes_thuringia = other_votes_fix;

let allocatedSeats = 0;
let remainders = [];

for (var party of Q.parties) {
    let rawSeats = Q[party + '_tl'] * 0.72;
    let seats = Math.floor(rawSeats);
    Q[party + '_seats_thuringia'] = seats;
    allocatedSeats += seats;
    remainders.push({
        party: party,
        remainder: rawSeats - seats
    });
}

let remainingSeats = 72 - allocatedSeats;
remainders.sort((a, b) => b.remainder - a.remainder);
for (let i = 0; i < remainingSeats && i < remainders.length; i++) {
    let partyObj = remainders[i];
    if (!partyObj || !partyObj.party) continue;

    let party = partyObj.party;
    Q[party + '_seats_thuringia'] += 1;
}



for (var party of Q.parties) {
    Q[party + '_tl'] = parseFloat((Q[party + '_seats_thuringia']/0.72).toFixed(1));
}





// coalitions
Q.united_left_coalition_thuringia = parseFloat((Q.spd_tl + Q.kpd_tl).toFixed(1));
Q.grand_coalition_thuringia = parseFloat((Q.nlp_tl + Q.fvp_tl + Q.z_tl + Q.spd_tl).toFixed(1));
Q.bourgeois_coalition_thuringia = parseFloat((Q.nlp_tl + Q.fvp_tl + Q.z_tl + Q.wp_tl + Q.rlb_tl + Q.csvd_tl).toFixed(1));
if (Q.rdp_formed) Q.bourgeois_coalition_thuringia = parseFloat((Q.bourgeois_coalition_thuringia - Q.fvp_tl).toFixed(1));
Q.right_coalition_thuringia = parseFloat((Q.dnvp_tl + Q.nlp_tl + Q.z_tl + Q.wp_tl + Q.rlb_tl + Q.csvd_tl + Q.kvp_tl + Q.kswr_tl).toFixed(1));


// Reset government and ministers...
Q.was_nlp_thuringia = 0;
Q.was_in_nlp_majority_thuringia = 0;
Q.was_in_united_left_coalition_thuringia = 0;
Q.was_in_grand_coalition_thuringia = 0;
Q.was_in_bourgeois_coalition_thuringia = 0;
Q.was_in_right_coalition_thuringia = 0;

if (Q.nlp_thuringia) Q.was_nlp_thuringia = 1;
if (Q.in_nlp_majority_thuringia) Q.was_in_nlp_majority_thuringia = 1;
if (Q.in_united_left_coalition_thuringia) Q.was_in_united_left_coalition_thuringia = 1;
if (Q.in_grand_coalition_thuringia) Q.was_in_grand_coalition_thuringia = 1;
if (Q.in_bourgeois_coalition_thuringia) Q.was_in_bourgeois_coalition_thuringia = 1;
if (Q.in_right_coalition_thuringia) Q.was_in_right_coalition_thuringia = 1;

Q.nlp_thuringia = 0;
Q.in_nlp_majority_thuringia = 0;
Q.in_united_left_coalition_thuringia = 0;
Q.in_grand_coalition_thuringia = 0;
Q.in_bourgeois_coalition_thuringia = 0;
Q.in_right_coalition_thuringia = 0;
Q.in_spd_kpd_toleration_thuringia = 0;
!}
on-display: {!
data = []
if (Q.kpd_seats_thuringia) {
    data.push({
        "id": "kpd",
        "legend": "KPD",
        "name": "KPD",
        "seats": Math.round(Q.kpd_seats_thuringia),
    });
}
if (Q.spd_seats_thuringia) {
    data.push({
        "id": "spd",
        "legend": "SPD",
        "name": "SPD",
        "seats": Math.round(Q.spd_seats_thuringia),
    });
}
if (Q.fvp_seats_thuringia && Q.rdp_formed) {
    data.push({
        "id": "rdp",
        "legend": Q.fvp_name,
        "name": Q.fvp_name,
        "seats": Math.round(Q.fvp_seats_thuringia),
    });
}
if (Q.fvp_seats_thuringia && !Q.rdp_formed) {
    data.push({
        "id": "fvp",
        "legend": Q.fvp_name,
        "name": Q.fvp_name,
        "seats": Math.round(Q.fvp_seats_thuringia),
    });
}
if (Q.nlp_seats_thuringia && Q.vldp_formed) {
    data.push({
        "id": "vldp",
        "legend": Q.nlp_name,
        "name": Q.nlp_name,
        "seats": Math.round(Q.nlp_seats_thuringia),
    });
}
if (Q.z_seats_thuringia) {
    data.push({
        "id": "z",
        "legend": "Center",
        "name": "Center",
        "seats": Math.round(Q.z_seats_thuringia),
    });
}
if (Q.nlp_seats_thuringia && !Q.vldp_formed) {
    data.push({
        "id": "nlp",
        "legend": Q.nlp_name,
        "name": Q.nlp_name,
        "seats": Math.round(Q.nlp_seats_thuringia),
    });
}
if (Q.csvd_exist && Q.csvd_seats_thuringia) {
    data.push({
        "id": "csvd",
        "legend": "CSVD",
        "name": "CSVD",
        "seats": Math.round(Q.csvd_seats_thuringia),
    });
}
if (Q.wp_exist && Q.wp_seats_thuringia) {
    data.push({
        "id": "wp",
        "legend": "WP",
        "name": "WP",
        "seats": Math.round(Q.wp_seats_thuringia),
    });
}
if (Q.rlb_exist && Q.rlb_seats_thuringia) {
    data.push({
        "id": "thlb",
        "legend": "ThLB",
        "name": "ThLB",
        "seats": Math.round(Q.rlb_seats_thuringia),
    });
}
if (Q.other_seats_thuringia) {
    data.push({
        "id": "other",
        "legend": "Other",
        "name": "Other",
        "seats": Math.round(Q.other_seats_thuringia),
    });
}
if (Q.kvp_exist && Q.kvp_seats_thuringia) {
    data.push({
        "id": "kvp",
        "legend": "KVP",
        "name": "KVP",
        "seats": Math.round(Q.kvp_seats_thuringia),
    });
}
if (Q.dnvp_seats_thuringia) {
    data.push({
        "id": "dnvp",
        "legend": "DNVP",
        "name": "DNVP",
        "seats": Math.round(Q.dnvp_seats_thuringia),
    });
}
if (Q.kswr_exist && Q.kswr_seats_thuringia) {
    data.push({
        "id": "kswr",
        "legend": "KSWR",
        "name": "KSWR",
        "seats": Math.round(Q.kswr_seats_thuringia),
    });
}
if (Q.dap_seats_thuringia) {
    data.push({
        "id": "dap",
        "legend": "DAP",
        "name": "DAP",
        "seats": Math.round(Q.dap_seats_thuringia),
    });
}

if (window && d3) {
    var width = 500; 
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50; 
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    } 

    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);
}
!}
go-to: thuringia_coalition_menu

