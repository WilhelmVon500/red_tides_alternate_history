{!<tr><td><div class="box" style='background-color:#909090'> </div> !} Others: {!</td><td>!} [+ other_election_votes_thuringia +]% {!</td><td>!} [+ other_seats_thuringia +] ([+ other_tl +]%) {!</td></tr>!}
