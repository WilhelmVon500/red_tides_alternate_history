{!<tr><td><div class="box" style='background-color:#3F7BC1'> </div> !} DNVP: {!</td><td>!} [+ dnvp_election_votes_thuringia +]% {!</td><td>!} [+ dnvp_seats_thuringia +] ([+ dnvp_tl +]%) {!</td></tr>!}

