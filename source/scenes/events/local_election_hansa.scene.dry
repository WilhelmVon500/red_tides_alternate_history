@ross
title: Rudolf Ross (<span style="color: #E3000F;">**SPD**</span>).
view-if: in_united_left_coalition_hansa or in_grand_coalition_hansa or in_weimar_coalition_hansa
on-arrival: hansa_leader = "Ross"; hansa_leader_party = "SPD";
face-image: img/portraits/RossRudolf.jpg

WIP.

@petersen_fvp
title: Carl Wilhelm Petersen (<span style="color: var(--fvp-color);">**[+ fvp_name +]**</span>).
view-if: not vldp_formed and (in_grand_coalition_hansa or in_bourgeois_coalition_hansa or in_weimar_coalition_hansa)
on-arrival: hansa_leader = "Petersen"; hansa_leader_party = fvp_name;
face-image: img/portraits/PetersenCarlWilhelm.jpg

WIP.

@lienau
title: Cay Diedrich Lienau ([?if not kswr_exist:<span style="color: #3F7BC1;">**DNVP**</span>?][?if kswr_exist:<span style="color: #003755;">**KSWR**</span>?]).
view-if: in_right_coalition_hansa
on-arrival: hansa_leader = "Lienau"; hansa_leader_party = "DNVP" if not kswr_exist; hansa_leader_party = "KSWR" if kswr_exist;
face-image: img/portraits/LienauCayDiedrich.jpg

