@petersen_nlp
title: Carl Wilhelm Petersen (<span style="color: var(--nlp-color);">**[+ nlp_name +]**</span>, Constitutional Liberal).
view-if: nlp_hansa and vldp_formed
choose-if: in_nlp_majority_hansa or in_bourgeois_coalition_hansa or in_right_coalition_hansa or (in_grand_coalition_hansa and nlp_hl > spd_hl)
unavailable-subtitle: Petersen doesn't have needed support to become the Senate President.
on-arrival: hansa_leader = "Petersen"; hansa_leader_party = nlp_name;
face-image: img/portraits/PetersenCarlWilhelm.jpg

