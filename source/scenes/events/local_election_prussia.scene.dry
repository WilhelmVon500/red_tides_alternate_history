@fischbeck_fvp
title: Otto Fischbeck (<span style="color: var(--fvp-color);">**[+ fvp_name +]**</span>).
view-if: not vldp_formed and (in_weimar_coalition_prussia or in_grand_coalition_prussia or in_bourgeois_coalition_prussia or in_center_right_coalition_prussia)
choose-if: (in_weimar_coalition_prussia and fvp_pl + z_pl > spd_pl) or (in_grand_coalition_prussia and nlp_pl + fvp_pl + z_pl > spd_pl) or in_bourgeois_coalition_prussia or in_center_right_coalition_prussia
unavailable-subtitle: Fischbeck doesn't have needed support to become the Minister-President.
on-arrival: prussia_leader = "Fischbeck"; prussia_leader_party = fvp_name;
