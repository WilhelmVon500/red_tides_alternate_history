@states

= Free State of Prussia

<div style="display: flex; justify-content: center;">[? if prussia_leader = "Braun": <img src="img/portraits/BraunOtto.jpg" class="prussia-leader"> ?][? if prussia_leader = "Kardorff": <img src="img/portraits/KardorffSiegfried.jpg" class="prussia-leader"> ?][? if prussia_leader = "Schwarzhaupt": <img src="img/portraits/SchwarzhauptWilhelm.jpg" class="prussia-leader"> ?][? if prussia_leader = "Stendel": <img src="img/portraits/StendelErnst.jpg" class="prussia-leader"> ?]</div>

