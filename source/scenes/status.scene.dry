title: Status
new-page: true
is-special: true
on-arrival: {!
if (Q.unemployed) {
    Q.unemployed_2 = Q.unemployed.toFixed(1);
}
if (Q.inflation) {
    Q.inflation_2 = Q.inflation.toFixed(1);
}
Q.economic_growth_2 = '0';
if (Q.economic_growth) {
    Q.economic_growth_2 = Q.economic_growth.toFixed(1);
}
!}

= Status

[+ month : month +] [+ year +][? if weeks_enabled:, Week [+ week +]?]

Resources available: [+ resources +]

<span style="color: var(--nlp-color);">**[+ nlp_name +]**</span> position: [? if nlp_in_government : in government - ?][? if not nlp_in_government and not nlp_toleration: opposition - ?]
[? if caretaker: Caretaker  ?][? if in_weimar_coalition: Weimar Coalition ?][? if in_center_right_coalition: Center-Right Coalition ?][? if in_right_coalition: Right Coalition ?][? if in_nlp_majority: <span style="color: var(--nlp-color);">**[+ nlp_name +]**</span> majority ?]

[? if nlp_in_government and not in_nlp_majority: Coalition dissent: [+ coalition_dissent : coalition_dissent +] ?]

Internal dissent: [+ dissent_percent : dissent +]

