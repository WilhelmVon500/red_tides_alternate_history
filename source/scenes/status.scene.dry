Government: [? if in_grand_coalition_bavaria: Grand Coalition ?][? if in_bourgeois_coalition_bavaria: Bourgeois Coalition ?][? if in_right_coalition_bavaria: Right Coalition ?][? if in_nlp_majority_bavaria: <span style="color: var(--nlp-color);">**[+ nlp_name +]**</span> majority ?]

